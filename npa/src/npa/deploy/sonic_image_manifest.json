{
  "format": "npa_sonic_image_manifest_v1",
  "tool": "sonic",
  "default_variant": "sonic-l40s-baked",
  "images": [
    {
      "id": "sonic-l40s-baked",
      "name": "npa-sonic",
      "tag": "0.1.2",
      "purpose": "Self-contained SONIC runtime for compute-only VM hosts that do not mount NVIDIA graphics userspace.",
      "base": {
        "cuda": "12.8",
        "torch": "2.7.0+cu128",
        "isaac_lab": "2.3.2.post1",
        "image": "nvcr.io/nvidia/isaac-lab:2.3.2@sha256:388dbc806f48359a964cb9f807feb226da95d0a107f470fdcad9780ea10fe6f2"
      },
      "driver_provisioning": "baked",
      "gpu_compatibility": [
        {
          "gpu": "L40S",
          "provider_model": "Nebius VM, compute-only host driver",
          "why": "The host does not provide the graphics userspace Isaac Lab needs, so the image carries the matching NVIDIA GL, NVML, and Vulkan libraries."
        }
      ],
      "build": {
        "command": "npa/docker/workbench/sonic/build.sh --registry ${NPA_REGISTRY} --push --variant baked",
        "dockerfile": "npa/docker/workbench/sonic/Dockerfile",
        "driver_coupled_packages": [
          "libnvidia-cfg1-580",
          "libnvidia-common-580",
          "libnvidia-compute-580",
          "libnvidia-decode-580",
          "libnvidia-gl-580",
          "libnvidia-gpucomp-580"
        ]
      },
      "digest": "sha256:bdf81f5b7f1c879ac920df53588a15129b2ac71d9492e8c2fc34ce636a5373fb"
    },
    {
      "id": "sonic-k8s-host-mounted",
      "name": "npa-sonic",
      "tag": "0.1.2-k8s-runtime",
      "purpose": "SONIC runtime for GPU-operator-managed Kubernetes nodes where the NVIDIA host driver is mounted into the container.",
      "base": {
        "cuda": "13.0",
        "torch": "2.9.0+cu130",
        "isaac_lab": "2.3.2.post1",
        "isaac_sim": "5.1.0",
        "image": "npa-base:cuda13-b300-sm80-sm90-sm120-latest"
      },
      "driver_provisioning": "host-mounted",
      "gpu_compatibility": [
        {
          "gpu": "RTX PRO 6000 Blackwell",
          "provider_model": "Nebius Managed Kubernetes with NVIDIA GPU Operator",
          "why": "The GPU Operator mounts driver-matched NVML, GL, and Vulkan userspace from the node, so the image must not carry conflicting driver-coupled libraries."
        },
        {
          "gpu": "Blackwell sm_120",
          "provider_model": "Kubernetes with NVIDIA GPU Operator",
          "why": "Use the CUDA 13 sm_120 PyTorch base, the operator-mounted driver stack, and NVIDIA_DRIVER_CAPABILITIES=all."
        }
      ],
      "build": {
        "command": "npa/docker/workbench/sonic/build.sh --registry ${NPA_REGISTRY} --push --variant k8s --tag 0.1.2-k8s-runtime",
        "dockerfile": "npa/docker/workbench/sonic/Dockerfile",
        "driver_coupled_packages": []
      },
      "digest": "sha256:bc246a1b2bc3038de5443107bb9ff34db9dddbe4cc15bac5b51a68b5e335e1d2"
    },
    {
      "id": "sonic-mujoco-h100-mvp",
      "name": "npa-sonic-mujoco",
      "tag": "0.1.3-mvp",
      "purpose": "Combined SONIC fine-tuning and MuJoCo evaluation runtime for the first G1 MVP milestone.",
      "base": {
        "cuda": "12.8",
        "torch": "2.7.0+cu128",
        "isaac_lab": "2.3.2.post1",
        "image": "npa-sonic:0.1.2"
      },
      "driver_provisioning": "baked",
      "gpu_compatibility": [
        {
          "gpu": "H100",
          "provider_model": "Nebius VM, compute-only host driver",
          "why": "The SONIC release fine-tune path is state/proprioceptive and headless; MuJoCo eval uses EGL/headless physics and does not require RT-core rendering."
        },
        {
          "gpu": "H200",
          "provider_model": "Nebius VM, compute-only host driver",
          "why": "Capacity fallback for the same headless state-based workload when H100 spot capacity is unavailable."
        }
      ],
      "build": {
        "command": "npa/docker/workbench/sonic/build.sh --registry ${NPA_REGISTRY} --push --variant mujoco --tag 0.1.3-mvp",
        "dockerfile": "npa/docker/workbench/sonic/Dockerfile.mujoco",
        "driver_coupled_packages": [
          "inherited from npa-sonic:0.1.2"
        ],
        "additional_packages": [
          "mujoco>=3.3,<3.4",
          "boto3",
          "headless EGL/GL runtime libraries"
        ]
      },
      "digest": "sha256:a9939d92106757e70b7b5ef94c7428aad0be0d000358634348f7e2184cf50f7d"
    }
  ],
  "gpu_selection": [
    {
      "variant": "sonic-mujoco-h100-mvp",
      "matches": [
        "h100",
        "gpu-h100",
        "gpu-h100-sxm",
        "h200",
        "gpu-h200",
        "gpu-h200-sxm",
        "sonic-mujoco"
      ]
    },
    {
      "variant": "sonic-k8s-host-mounted",
      "matches": [
        "rtx6000",
        "rtx-pro-6000",
        "rtx pro 6000",
        "blackwell",
        "sm_120",
        "gpu-rtx6000",
        "gpu-rtx-pro-6000"
      ]
    },
    {
      "variant": "sonic-l40s-baked",
      "matches": [
        "l40s",
        "gpu-l40s-a",
        "gpu-l40s-d"
      ]
    }
  ]
}
