# Copy to ~/.npa/sim2real-operator.env (chmod 600)
# Full-pipeline demo: industrial UR5e + LeRobot public pusht + 800 envs on RTX mk8s.
#
# After seed-trigger + seed-industrial-production-assets, replace YOUR-* placeholders.

# --- LeRobot trigger (public demo data — Hugging Face lerobot/pusht) ---
TRIGGER_DATASET_URI=s3://YOUR-BUCKET/sim2real-triggers/YOUR-BATCH-ID/lerobot-pusht/
TRIGGER_DATASET_ID=lerobot/pusht

# --- Pipeline scale (demo = 800 envs; production validation = 10000) ---
NPA_ENV_COUNT=800
INNER_ITERATIONS=2
OUTER_ITERATIONS=2
NPA_SIM2REAL_HELDOUT_EVAL_LIMIT=8

# --- Sim backends ---
NPA_SIM2REAL_SIM_BACKEND=isaac
NPA_SIM2REAL_ISAAC_TASK=Isaac-Lift-Cube-Franka-v0

# --- Industrial asset profile (UR5e + custom scene/cameras on S3) ---
CUSTOMER_ASSET_PROFILE=industrial
CUSTOMER_TASK_ID=YOUR-TASK-ID
CUSTOMER_ROBOT_PRESET=ur5e

# --- Cosmos VLM (registry tags resolved at submit unless overridden) ---
VLM_REASON2_MODEL=nvidia/Cosmos-Reason2-8B
VLM_REASON3_MODEL=nvidia/Cosmos-Reason2-2B
NPA_SIM2REAL_VLM_DUAL_REASON=1

# --- LeRobot trainer container (NPA workbench image in your registry) ---
# TRAINER_IMAGE=YOUR-REGISTRY/npa-lerobot-vlm-rl:0.1.0

# --- Job timeouts (800-env demo; increase for 10k) ---
MONITOR_TIMEOUT_S=7200
NPA_SIM2REAL_K8S_JOB_TIMEOUT_S=10800
