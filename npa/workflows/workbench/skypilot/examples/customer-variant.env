# Example customer/run variant overlay for the BDD100K pipeline.
#
# A variant is an env overlay, never a forked YAML. Apply it at submission:
#   sky jobs launch --env-file customer-variant.env bdd100k-pipeline.generated.yaml
# or with the runner / workflow submit:
#   npa workbench workflow submit bdd100k-pipeline.generated.yaml \
#     --var NPA_PIPELINE_RUN_ID=acme-2026wk24 --var DETECTION_TRAINING_ENDPOINT=...
#
# Only override what differs for this customer/run; everything else stays default.

NPA_PIPELINE_RUN_ID=acme-2026wk24

# In-cluster service endpoints (override if the customer's service names differ).
LANCEDB_ENDPOINT=http://npa-lancedb.workbench.svc.cluster.local:8686
DETECTION_TRAINING_ENDPOINT=http://npa-detection-training.workbench.svc.cluster.local:8790

# Real-data run: switch the synthetic label map to the real BDD100K det_20 names.
# (person->pedestrian, motor->motorcycle, bike->bicycle)
BDD100K_LABEL_MAP={"pedestrian":0,"rider":1,"car":2,"truck":3,"bus":4,"train":5,"motorcycle":6,"bicycle":7,"traffic light":8,"traffic sign":9}

# Ingest real frames instead of synthetic rows.
BDD100K_SYNTHETIC_ROWS=0

# Training knobs.
TRAIN_EPOCHS=10

# Write canonical eval metrics.json to S3 (1) or skip (0).
WRITE_CANONICAL_EVAL_METRICS=1
