# Industrial production — robot, objects, scene fixtures, and cameras in one profile.
# Set ROBOT_PRESET to ur5e | ur10e | flexiv. Upload JSON/meshes at the URIs below.

ROBOT_MODE=preset
ROBOT_PRESET=ur5e
ROBOT_SPEC_URI=s3://YOUR-BUCKET/sim2real-assets/YOUR-TASK-ID/robot-spec.json

SCENE_MODE=custom
OBJECT_MODE=scene_spec
CAMERA_MODE=custom
SCENE_SPEC_URI=s3://YOUR-BUCKET/sim2real-assets/YOUR-TASK-ID/scene-spec.json

# Mesh-only manipuland on stock table + stock cameras (omit SCENE_SPEC_URI):
# OBJECT_MODE=mesh
# SCENE_MODE=stock
# CAMERA_MODE=stock
# ASSETS_URI=s3://YOUR-BUCKET/sim2real-assets/YOUR-TASK-ID/part.obj

# Cameras in a separate JSON instead of the scene-spec cameras block:
# CAMERA_MODE=custom
# CAMERAS_URI=s3://YOUR-BUCKET/sim2real-assets/YOUR-TASK-ID/cameras.json
