# /etc/npa-lerobot-server/env
# Configuration for npa-lerobot-server systemd service.
# Copy this to /etc/npa-lerobot-server/env and fill in values.

NPA_SERVER_HOST=0.0.0.0
NPA_SERVER_PORT=8080
NPA_CHECKPOINT_DIR=/opt/lerobot/checkpoints
NPA_CHECKPOINT_BUCKET=
NPA_JOB_STATUS_DIR=/opt/lerobot/job_status
NPA_LOG_DIR=/var/log/npa-lerobot

# S3-compatible object storage (Nebius)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=

# HuggingFace Hub
HF_TOKEN=
