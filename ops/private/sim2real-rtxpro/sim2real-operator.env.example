# Sim2Real operator env — copy to ~/.npa/sim2real-operator.env (chmod 600)
# Registry-qualified images are filled from storage.registry at submit time unless set here.

# --- Stock Franka demo trigger (no ASSETS_URI / SCENE_SPEC_URI) ---
TRIGGER_DATASET_URI=s3://YOUR-BUCKET/sim2real-triggers/YOUR-BATCH-ID/lerobot-pusht/
TRIGGER_DATASET_ID=lerobot/pusht

# --- Loop depth ---
INNER_ITERATIONS=1
OUTER_ITERATIONS=2

# --- Cosmos (latest pinned — matches npa/pyproject.toml) ---
# VLM_IMAGE=<registry>/npa-cosmos3-reason:3.0.1-genuine-sm120
# AUGMENT_IMAGE=<registry>/npa-cosmos2-transfer:2.5.0
VLM_REASON2_MODEL=nvidia/Cosmos-Reason2-8B
VLM_REASON3_MODEL=nvidia/Cosmos-Reason2-2B
NPA_SIM2REAL_VLM_DUAL_REASON=1

# --- Sim backend ---
NPA_SIM2REAL_SIM_BACKEND=isaac
NPA_SIM2REAL_ISAAC_TASK=Isaac-Lift-Cube-Franka-v0

# --- Optional tuning ---
# ROLLOUT_COUNT=8
# HELDOUT_ENV_COUNT=8
# NPA_ENVGEN_SHARD_COUNT=16
# SUCCESS_THRESHOLD=0.45
