package_update: true
package_upgrade: false

%{ if enable_filestore != "false" }
mounts:
- [ data, ${filestore_mount_path}, virtiofs, "defaults", 0, 2 ]

runcmd:
 - [ modprobe, fuse ]
 - [ mkdir, '-p', ${filestore_mount_path} ]
 - [ mount, '-a' ]
 
%{ endif }

users:
 - name: ${ssh_user_name}
   sudo: ALL=(ALL) NOPASSWD:ALL
   shell: /bin/bash
   ssh_authorized_keys:
    - ${ssh_public_key}
